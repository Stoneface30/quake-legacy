# Visual-record gameplay frames — contain player nameplates / HUD (PII)
# Only docs/visual-record/github-readme/ is safe for public (manually curated)
# Exclude image files under style-lock / gameplay / render subfolders, keep READMEs
docs/visual-record/*/part*-style-lock/*.jpg
docs/visual-record/*/part*-style-lock/*.png
docs/visual-record/*/gameplay-frames/*.jpg
docs/visual-record/*/gameplay-frames/*.png
docs/visual-record/*/render-frames/*.jpg
docs/visual-record/*/render-frames/*.png
phase1/music/library/
# Copyrighted music — kept local, never committed to public repo (Rule P1-R assets)
phase1/music/*.mp3
phase1/music/*.ogg
phase1/music/*.wav
phase1/music/*.flac
phase1/music/_stitched/


# Creative Suite v2 local storage
storage/

# 2026-04-19 video tooling upgrade — downloaded binaries stay local, never committed
tools/ffmpeg-7/
tools/ffmpeg-8/
tools/virtualdub2/
tools/davinci/
tools/premiere/
tools/aftereffects/
tools/topaz/
*.iso

# Creative Suite v2 — ComfyUI runtime (model weights, custom nodes, I/O are
# regenerable and would bloat the repo / license-leak model files).
tools/comfyui/models/**
tools/comfyui/custom_nodes/**
tools/comfyui/output/**
tools/comfyui/input/**
tools/comfyui/ComfyUI/**
tools/comfyui/python_embeded/**
tools/comfyui/update/**
tools/comfyui/*.7z
tools/comfyui/*.bat
# But keep a top-level README if we write one
!tools/comfyui/README.md

# Engine consolidation — canonical tree and per-tree variants (third-party source,
# too large + license-mixed for public repo). Only manifest/diffs/docs are tracked.
engine/engines/_canonical/
engine/engines/darkplaces/
engine/engines/demodumper/
engine/engines/gtkradiant/
engine/engines/ioquake3/
engine/engines/openarena-engine/
engine/engines/openarena-gamecode/
engine/engines/q3mme/
engine/engines/q3vm/
engine/engines/qldemo-python/
engine/engines/quake1-source/
engine/engines/quake2-source/
engine/engines/quake3-source/
engine/engines/quake3e/
engine/engines/uberdemotools/
engine/engines/wolfcamql-src/
engine/engines/wolfcamql-local-src/
engine/engines/wolfet-source/
engine/engines/yamagi-quake2/
# But DO track the inventory, diffs, and docs:
!engine/engines/_manifest/
!engine/engines/_diffs/
!engine/engines/*.md

# Private nickname map — sha8(nick) -> real nickname. NEVER commit.
.nickname_map.json

# Ghidra sandbox (FT-4 reverse-engineering track)
# Projects are huge (.gpr + .rep per-binary databases). Binaries are id Software IP
# (QL / Q3A derivatives) — reference only, never redistribute. Reports + scripts
# + ipc-maps + symbols ARE committed — that is the deliverable.
engine/ghidra/projects/
engine/ghidra/binaries/
engine/ghidra/_staging_extract/
!engine/ghidra/reports/
!engine/ghidra/scripts/
!engine/ghidra/ipc-maps/
!engine/ghidra/symbols/
!engine/ghidra/README.md

