{
  "_template_version": "1",
  "_description": "JuggernautXL + TTPLanet Tile ControlNet + LoRA style injection. Supports any SDXL LoRA. Placeholders: lora_name, lora_strength (0.4–0.9 typical).",
  "_placeholders": ["{{input_image}}", "{{prompt}}", "{{seed}}", "{{denoise}}", "{{negative_prompt}}", "{{lora_name}}", "{{lora_strength}}"],
  "1": {
    "class_type": "CheckpointLoaderSimple",
    "inputs": { "ckpt_name": "juggernautXL_ragnarokBy.safetensors" }
  },
  "2": {
    "class_type": "LoraLoader",
    "_comment": "Style LoRA — swap lora_name for any SDXL LoRA. Set strength 0.0 to bypass.",
    "inputs": {
      "model": ["1", 0],
      "clip":  ["1", 1],
      "lora_name":       "{{lora_name}}",
      "strength_model":  "{{lora_strength}}",
      "strength_clip":   "{{lora_strength}}"
    }
  },
  "3": {
    "class_type": "LoadImage",
    "inputs": { "image": "{{input_image}}" }
  },
  "4": {
    "class_type": "UpscaleModelLoader",
    "inputs": { "model_name": "4x-UltraSharp.pth" }
  },
  "5": {
    "class_type": "ImageUpscaleWithModel",
    "inputs": { "upscale_model": ["4", 0], "image": ["3", 0] }
  },
  "6": {
    "class_type": "ImageScaleBy",
    "inputs": { "image": ["5", 0], "upscale_method": "lanczos", "scale_by": 0.5 }
  },
  "7": {
    "class_type": "TTPlanet_TileGF_Preprocessor",
    "inputs": {
      "image": ["6", 0],
      "scale_factor": 1.0,
      "blur_strength": 2.0,
      "radius": 7,
      "eps": 0.01,
      "resolution": 512
    }
  },
  "8": {
    "class_type": "VAEEncode",
    "inputs": { "pixels": ["6", 0], "vae": ["1", 2] }
  },
  "9": {
    "class_type": "ControlNetLoader",
    "inputs": { "control_net_name": "TTPLANET_Controlnet_Tile_realistic_v2_fp16.safetensors" }
  },
  "10": {
    "class_type": "CLIPTextEncode",
    "inputs": { "text": "{{prompt}}", "clip": ["2", 1] }
  },
  "11": {
    "class_type": "CLIPTextEncode",
    "inputs": { "text": "{{negative_prompt}}", "clip": ["2", 1] }
  },
  "12": {
    "class_type": "ControlNetApplyAdvanced",
    "inputs": {
      "positive":      ["10", 0],
      "negative":      ["11", 0],
      "control_net":   ["9", 0],
      "image":         ["7", 0],
      "strength":      1.0,
      "start_percent": 0.0,
      "end_percent":   1.0
    }
  },
  "13": {
    "class_type": "KSampler",
    "inputs": {
      "model":        ["2", 0],
      "positive":     ["12", 0],
      "negative":     ["12", 1],
      "latent_image": ["8", 0],
      "seed":         "{{seed}}",
      "steps":        25,
      "cfg":          7.0,
      "sampler_name": "dpmpp_2m",
      "scheduler":    "karras",
      "denoise":      "{{denoise}}"
    }
  },
  "14": {
    "class_type": "VAEDecode",
    "inputs": { "samples": ["13", 0], "vae": ["1", 2] }
  },
  "15": {
    "class_type": "SaveImage",
    "inputs": { "images": ["14", 0], "filename_prefix": "creative_suite/lora_style" }
  }
}
