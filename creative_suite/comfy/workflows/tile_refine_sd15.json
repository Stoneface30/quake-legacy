{
  "_template_version": "1",
  "_description": "ControlNet-Tile refinement on already-processed images (no re-upscale). Use for pass2/pass3 on top of tile_controlnet_sd15 pass1 outputs.",
  "_placeholders": ["{{input_image}}", "{{prompt}}", "{{seed}}", "{{denoise}}", "{{negative_prompt}}"],
  "1": {
    "class_type": "CheckpointLoaderSimple",
    "inputs": { "ckpt_name": "dreamshaper_8.safetensors" }
  },
  "2": {
    "class_type": "LoadImage",
    "inputs": { "image": "{{input_image}}" }
  },
  "3": {
    "class_type": "VAEEncode",
    "inputs": { "pixels": ["2", 0], "vae": ["1", 2] }
  },
  "4": {
    "class_type": "ControlNetLoader",
    "inputs": { "control_net_name": "control_v11f1e_sd15_tile.pth" }
  },
  "5": {
    "class_type": "CLIPTextEncode",
    "inputs": { "text": "{{prompt}}", "clip": ["1", 1] }
  },
  "6": {
    "class_type": "CLIPTextEncode",
    "inputs": { "text": "{{negative_prompt}}", "clip": ["1", 1] }
  },
  "7": {
    "class_type": "ControlNetApplyAdvanced",
    "inputs": {
      "positive": ["5", 0],
      "negative": ["6", 0],
      "control_net": ["4", 0],
      "image": ["2", 0],
      "strength": 1.0,
      "start_percent": 0.0,
      "end_percent": 1.0
    }
  },
  "8": {
    "class_type": "KSampler",
    "inputs": {
      "model": ["1", 0],
      "positive": ["7", 0],
      "negative": ["7", 1],
      "latent_image": ["3", 0],
      "seed": "{{seed}}",
      "steps": 20,
      "cfg": 7.0,
      "sampler_name": "dpmpp_2m",
      "scheduler": "karras",
      "denoise": "{{denoise}}"
    }
  },
  "9": {
    "class_type": "VAEDecode",
    "inputs": { "samples": ["8", 0], "vae": ["1", 2] }
  },
  "10": {
    "class_type": "SaveImage",
    "inputs": {
      "images": ["9", 0],
      "filename_prefix": "creative_suite/refine"
    }
  }
}
