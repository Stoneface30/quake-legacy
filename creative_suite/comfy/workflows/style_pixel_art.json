{
  "_template_version": "3",
  "_description": "JuggernautXL + pixel-art-xl LoRA + TTPLanet Tile. Converts textures to retro pixel-art style while preserving UV structure. LoRA on disk: pixel-art-xl.safetensors (163MB). Higher denoise=0.55 lets LoRA transform fully. No internal upscale.",
  "_style": "pixel_art",
  "_placeholders": [
    "{{input_image}}",
    "{{prompt}}",
    "{{seed}}",
    "{{denoise}}",
    "{{negative_prompt}}"
  ],
  "1": {
    "class_type": "CheckpointLoaderSimple",
    "inputs": {
      "ckpt_name": "juggernautXL_ragnarokBy.safetensors"
    }
  },
  "2": {
    "class_type": "LoraLoader",
    "_comment": "pixel-art-xl.safetensors — on disk (163MB). strength 0.7 retains structure while applying pixel aesthetic.",
    "inputs": {
      "model": ["1", 0],
      "clip": ["1", 1],
      "lora_name": "pixel-art-xl.safetensors",
      "strength_model": 0.7,
      "strength_clip": 0.7
    }
  },
  "3": {
    "class_type": "LoadImage",
    "inputs": {
      "image": "{{input_image}}"
    }
  },
  "4": {
    "class_type": "TTPlanet_TileGF_Preprocessor",
    "_comment": "Tile ControlNet preserves UV layout — LoRA handles the pixel art transformation",
    "inputs": {
      "image": ["3", 0],
      "scale_factor": 1.0,
      "blur_strength": 2.0,
      "radius": 7,
      "eps": 0.01,
      "resolution": 512
    }
  },
  "5": {
    "class_type": "VAEEncode",
    "inputs": {
      "pixels": ["3", 0],
      "vae": ["1", 2]
    }
  },
  "6": {
    "class_type": "ControlNetLoader",
    "inputs": {
      "control_net_name": "TTPLANET_Controlnet_Tile_realistic_v2_fp16.safetensors"
    }
  },
  "7": {
    "class_type": "CLIPTextEncode",
    "_comment": "pixel art prompt prefix helps the LoRA — baked into workflow, not a placeholder",
    "inputs": {
      "text": "pixel art style, retro game texture, {{prompt}}",
      "clip": ["2", 1]
    }
  },
  "8": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "text": "{{negative_prompt}}",
      "clip": ["2", 1]
    }
  },
  "9": {
    "class_type": "ControlNetApplyAdvanced",
    "inputs": {
      "positive": ["7", 0],
      "negative": ["8", 0],
      "control_net": ["6", 0],
      "image": ["4", 0],
      "strength": 1.0,
      "start_percent": 0.0,
      "end_percent": 1.0
    }
  },
  "10": {
    "class_type": "KSampler",
    "_comment": "model from LoraLoader node 2 — not directly from checkpoint",
    "inputs": {
      "model": ["2", 0],
      "positive": ["9", 0],
      "negative": ["9", 1],
      "latent_image": ["5", 0],
      "seed": "{{seed}}",
      "steps": 15,
      "cfg": 7.0,
      "sampler_name": "dpmpp_2m",
      "scheduler": "karras",
      "denoise": "{{denoise}}"
    }
  },
  "11": {
    "class_type": "VAEDecode",
    "inputs": {
      "samples": ["10", 0],
      "vae": ["1", 2]
    }
  },
  "12": {
    "class_type": "SaveImage",
    "inputs": {
      "images": ["11", 0],
      "filename_prefix": "creative_suite/style_pixel_art"
    }
  }
}
