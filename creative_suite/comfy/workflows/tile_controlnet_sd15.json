{
  "_template_version": "1",
  "_description": "4x-UltraSharp upscale \u2192 dreamshaper8 + ControlNet-Tile SD1.5. Preserves UV structure while adding photorealistic surface detail.",
  "_placeholders": [
    "{{input_image}}",
    "{{prompt}}",
    "{{seed}}",
    "{{denoise}}",
    "{{negative_prompt}}"
  ],
  "1": {
    "class_type": "CheckpointLoaderSimple",
    "inputs": {
      "ckpt_name": "dreamshaper_8.safetensors"
    }
  },
  "2": {
    "class_type": "LoadImage",
    "inputs": {
      "image": "{{input_image}}"
    }
  },
  "3": {
    "class_type": "UpscaleModelLoader",
    "inputs": {
      "model_name": "4x-UltraSharp.pth"
    }
  },
  "4": {
    "class_type": "ImageUpscaleWithModel",
    "inputs": {
      "upscale_model": [
        "3",
        0
      ],
      "image": [
        "2",
        0
      ]
    }
  },
  "5": {
    "class_type": "ImageScaleBy",
    "inputs": {
      "image": [
        "4",
        0
      ],
      "upscale_method": "lanczos",
      "scale_by": 0.5
    }
  },
  "6": {
    "class_type": "VAEEncode",
    "inputs": {
      "pixels": [
        "5",
        0
      ],
      "vae": [
        "1",
        2
      ]
    }
  },
  "7": {
    "class_type": "ControlNetLoader",
    "inputs": {
      "control_net_name": "control_v11f1e_sd15_tile.pth"
    }
  },
  "8": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "text": "{{prompt}}",
      "clip": [
        "1",
        1
      ]
    }
  },
  "9": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "text": "{{negative_prompt}}",
      "clip": [
        "1",
        1
      ]
    }
  },
  "10": {
    "class_type": "ControlNetApplyAdvanced",
    "inputs": {
      "positive": [
        "8",
        0
      ],
      "negative": [
        "9",
        0
      ],
      "control_net": [
        "7",
        0
      ],
      "image": [
        "5",
        0
      ],
      "strength": 1.0,
      "start_percent": 0.0,
      "end_percent": 1.0
    }
  },
  "11": {
    "class_type": "KSampler",
    "inputs": {
      "model": [
        "1",
        0
      ],
      "positive": [
        "10",
        0
      ],
      "negative": [
        "10",
        1
      ],
      "latent_image": [
        "6",
        0
      ],
      "seed": "{{seed}}",
      "steps": 15,
      "cfg": 7.0,
      "sampler_name": "dpmpp_2m",
      "scheduler": "karras",
      "denoise": "{{denoise}}"
    }
  },
  "12": {
    "class_type": "VAEDecode",
    "inputs": {
      "samples": [
        "11",
        0
      ],
      "vae": [
        "1",
        2
      ]
    }
  },
  "13": {
    "class_type": "SaveImage",
    "inputs": {
      "images": [
        "12",
        0
      ],
      "filename_prefix": "creative_suite/tile"
    }
  }
}