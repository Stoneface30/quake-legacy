{
  "_template_version": "2",
  "_description": "JuggernautXL + TTPLanet SDXL Tile ControlNet with TTPlanet_TileGF_Preprocessor. Correct pipeline: upscale -> preprocess conditioning -> img2img with SDXL structural control.",
  "_placeholders": [
    "{{input_image}}",
    "{{prompt}}",
    "{{seed}}",
    "{{denoise}}",
    "{{negative_prompt}}"
  ],
  "1": {
    "class_type": "CheckpointLoaderSimple",
    "inputs": {
      "ckpt_name": "juggernautXL_ragnarokBy.safetensors"
    }
  },
  "2": {
    "class_type": "LoadImage",
    "inputs": {
      "image": "{{input_image}}"
    }
  },
  "3": {
    "class_type": "UpscaleModelLoader",
    "inputs": {
      "model_name": "4x-UltraSharp.pth"
    }
  },
  "4": {
    "class_type": "ImageUpscaleWithModel",
    "inputs": {
      "upscale_model": [
        "3",
        0
      ],
      "image": [
        "2",
        0
      ]
    }
  },
  "5": {
    "class_type": "ImageScaleBy",
    "inputs": {
      "image": [
        "4",
        0
      ],
      "upscale_method": "lanczos",
      "scale_by": 0.5
    }
  },
  "6": {
    "class_type": "TTPlanet_TileGF_Preprocessor",
    "inputs": {
      "image": [
        "5",
        0
      ],
      "scale_factor": 1.0,
      "blur_strength": 2.0,
      "radius": 7,
      "eps": 0.01,
      "resolution": 512
    }
  },
  "7": {
    "class_type": "VAEEncode",
    "inputs": {
      "pixels": [
        "5",
        0
      ],
      "vae": [
        "1",
        2
      ]
    }
  },
  "8": {
    "class_type": "ControlNetLoader",
    "inputs": {
      "control_net_name": "TTPLANET_Controlnet_Tile_realistic_v2_fp16.safetensors"
    }
  },
  "9": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "text": "{{prompt}}",
      "clip": [
        "1",
        1
      ]
    }
  },
  "10": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "text": "{{negative_prompt}}",
      "clip": [
        "1",
        1
      ]
    }
  },
  "11": {
    "class_type": "ControlNetApplyAdvanced",
    "inputs": {
      "positive": [
        "9",
        0
      ],
      "negative": [
        "10",
        0
      ],
      "control_net": [
        "8",
        0
      ],
      "image": [
        "6",
        0
      ],
      "strength": 1.0,
      "start_percent": 0.0,
      "end_percent": 1.0
    }
  },
  "12": {
    "class_type": "KSampler",
    "inputs": {
      "model": [
        "1",
        0
      ],
      "positive": [
        "11",
        0
      ],
      "negative": [
        "11",
        1
      ],
      "latent_image": [
        "7",
        0
      ],
      "seed": "{{seed}}",
      "steps": 15,
      "cfg": 7.0,
      "sampler_name": "dpmpp_2m",
      "scheduler": "karras",
      "denoise": "{{denoise}}"
    }
  },
  "13": {
    "class_type": "VAEDecode",
    "inputs": {
      "samples": [
        "12",
        0
      ],
      "vae": [
        "1",
        2
      ]
    }
  },
  "14": {
    "class_type": "SaveImage",
    "inputs": {
      "images": [
        "13",
        0
      ],
      "filename_prefix": "creative_suite/tile_sdxl"
    }
  }
}