{
  "_template_version": "1",
  "_placeholders": [
    "{{input_image}}",
    "{{prompt}}",
    "{{seed}}",
    "{{denoise}}",
    "{{negative_prompt}}"
  ],
  "_notes": [
    "SDXL img2img + xinsir Union ProMax ControlNet in canny mode.",
    "Strength 0.55 preserves edges without over-constraining photoreal variation.",
    "ControlNet filename must match config_tools.yaml controlnet_canny.filename."
  ],
  "1": {
    "class_type": "CheckpointLoaderSimple",
    "inputs": {
      "ckpt_name": "RealVisXL_V5.0_fp16.safetensors"
    }
  },
  "2": {
    "class_type": "LoadImage",
    "inputs": {
      "image": "{{input_image}}"
    }
  },
  "3": {
    "class_type": "VAEEncode",
    "inputs": {
      "pixels": ["2", 0],
      "vae": ["1", 2]
    }
  },
  "4": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "text": "{{prompt}}",
      "clip": ["1", 1]
    }
  },
  "5": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "text": "{{negative_prompt}}",
      "clip": ["1", 1]
    }
  },
  "6": {
    "class_type": "KSampler",
    "inputs": {
      "seed": "{{seed}}",
      "steps": 28,
      "cfg": 6.0,
      "sampler_name": "dpmpp_2m_sde_gpu",
      "scheduler": "karras",
      "denoise": "{{denoise}}",
      "model": ["1", 0],
      "positive": ["11", 0],
      "negative": ["11", 1],
      "latent_image": ["3", 0]
    }
  },
  "7": {
    "class_type": "VAEDecode",
    "inputs": {
      "samples": ["6", 0],
      "vae": ["1", 2]
    }
  },
  "8": {
    "class_type": "SaveImage",
    "inputs": {
      "images": ["7", 0],
      "filename_prefix": "creative_suite/variant_canny"
    }
  },
  "9": {
    "class_type": "ControlNetLoader",
    "inputs": {
      "control_net_name": "xinsir-union-promax/diffusion_pytorch_model_promax.safetensors"
    }
  },
  "10": {
    "class_type": "Canny",
    "inputs": {
      "image": ["2", 0],
      "low_threshold": 0.4,
      "high_threshold": 0.8
    }
  },
  "11": {
    "class_type": "ControlNetApplyAdvanced",
    "inputs": {
      "strength": 0.55,
      "start_percent": 0.0,
      "end_percent": 0.8,
      "positive": ["4", 0],
      "negative": ["5", 0],
      "control_net": ["9", 0],
      "image": ["10", 0],
      "vae": ["1", 2]
    }
  }
}
