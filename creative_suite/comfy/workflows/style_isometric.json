{
  "_template_version": "4",
  "_description": "stylized-isometric-sdxl (SD1.5, 2GB) + Tile SD1.5 ControlNet — isometric game-art style. Fixed from v3: model is SD1.5 not SDXL despite the name; switched from TTPLanet SDXL to control_v11f1e_sd15_tile.pth. No preprocessor needed for SD1.5 tile. No internal upscale.",
  "_style": "isometric",
  "_placeholders": [
    "{{input_image}}",
    "{{prompt}}",
    "{{seed}}",
    "{{denoise}}",
    "{{negative_prompt}}"
  ],
  "1": {
    "class_type": "CheckpointLoaderSimple",
    "inputs": {
      "ckpt_name": "stylized-isometric-sdxl.safetensors"
    }
  },
  "2": {
    "class_type": "LoadImage",
    "inputs": {
      "image": "{{input_image}}"
    }
  },
  "3": {
    "class_type": "VAEEncode",
    "inputs": {
      "pixels": ["2", 0],
      "vae": ["1", 2]
    }
  },
  "4": {
    "class_type": "ControlNetLoader",
    "_comment": "SD1.5 Tile ControlNet — correct pairing for this SD1.5 checkpoint",
    "inputs": {
      "control_net_name": "control_v11f1e_sd15_tile.pth"
    }
  },
  "5": {
    "class_type": "CLIPTextEncode",
    "_comment": "isometric prefix activates model's stylization tendency",
    "inputs": {
      "text": "isometric game art, low poly style, {{prompt}}",
      "clip": ["1", 1]
    }
  },
  "6": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "text": "{{negative_prompt}}",
      "clip": ["1", 1]
    }
  },
  "7": {
    "class_type": "ControlNetApplyAdvanced",
    "inputs": {
      "positive": ["5", 0],
      "negative": ["6", 0],
      "control_net": ["4", 0],
      "image": ["2", 0],
      "strength": 0.9,
      "start_percent": 0.0,
      "end_percent": 1.0
    }
  },
  "8": {
    "class_type": "KSampler",
    "inputs": {
      "model": ["1", 0],
      "positive": ["7", 0],
      "negative": ["7", 1],
      "latent_image": ["3", 0],
      "seed": "{{seed}}",
      "steps": 15,
      "cfg": 7.0,
      "sampler_name": "dpmpp_2m",
      "scheduler": "karras",
      "denoise": "{{denoise}}"
    }
  },
  "9": {
    "class_type": "VAEDecode",
    "inputs": {
      "samples": ["8", 0],
      "vae": ["1", 2]
    }
  },
  "10": {
    "class_type": "SaveImage",
    "inputs": {
      "images": ["9", 0],
      "filename_prefix": "creative_suite/style_isometric"
    }
  }
}
