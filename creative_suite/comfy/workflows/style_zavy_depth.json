{
  "_template_version": "3",
  "_description": "ZavyChromaXL + DepthAnythingV2 + Depth SDXL ControlNet — vibrant chromatic colours with volumetric depth structure. ckpt on disk: depth_anything_v2_vitl.pth. No internal upscale.",
  "_style": "zavy_depth",
  "_placeholders": [
    "{{input_image}}",
    "{{prompt}}",
    "{{seed}}",
    "{{denoise}}",
    "{{negative_prompt}}"
  ],
  "1": {
    "class_type": "CheckpointLoaderSimple",
    "inputs": {
      "ckpt_name": "zavychromaxl_v100.safetensors"
    }
  },
  "2": {
    "class_type": "LoadImage",
    "inputs": {
      "image": "{{input_image}}"
    }
  },
  "3": {
    "class_type": "DepthAnythingV2Preprocessor",
    "_comment": "depth_anything_v2_vitl.pth already on disk",
    "inputs": {
      "image": ["2", 0],
      "ckpt_name": "depth_anything_v2_vitl.pth",
      "resolution": 512
    }
  },
  "4": {
    "class_type": "VAEEncode",
    "inputs": {
      "pixels": ["2", 0],
      "vae": ["1", 2]
    }
  },
  "5": {
    "class_type": "ControlNetLoader",
    "inputs": {
      "control_net_name": "controlnet-depth-sdxl-1.0.safetensors"
    }
  },
  "6": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "text": "{{prompt}}",
      "clip": ["1", 1]
    }
  },
  "7": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "text": "{{negative_prompt}}",
      "clip": ["1", 1]
    }
  },
  "8": {
    "class_type": "ControlNetApplyAdvanced",
    "inputs": {
      "positive": ["6", 0],
      "negative": ["7", 0],
      "control_net": ["5", 0],
      "image": ["3", 0],
      "strength": 0.6,
      "start_percent": 0.0,
      "end_percent": 0.85,
      "vae": ["1", 2]
    }
  },
  "9": {
    "class_type": "KSampler",
    "inputs": {
      "model": ["1", 0],
      "positive": ["8", 0],
      "negative": ["8", 1],
      "latent_image": ["4", 0],
      "seed": "{{seed}}",
      "steps": 15,
      "cfg": 6.0,
      "sampler_name": "dpmpp_2m_sde_gpu",
      "scheduler": "karras",
      "denoise": "{{denoise}}"
    }
  },
  "10": {
    "class_type": "VAEDecode",
    "inputs": {
      "samples": ["9", 0],
      "vae": ["1", 2]
    }
  },
  "11": {
    "class_type": "SaveImage",
    "inputs": {
      "images": ["10", 0],
      "filename_prefix": "creative_suite/style_zavy_depth"
    }
  }
}
