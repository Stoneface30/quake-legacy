{
  "_template_version": "3",
  "_description": "ZavyChromaXL + Canny SDXL ControlNet — edge-guided synthesis with chromatic palette. Sharp structural edges, vibrant fills. No internal upscale.",
  "_style": "edge_chrome",
  "_placeholders": [
    "{{input_image}}",
    "{{prompt}}",
    "{{seed}}",
    "{{denoise}}",
    "{{negative_prompt}}"
  ],
  "1": {
    "class_type": "CheckpointLoaderSimple",
    "inputs": {
      "ckpt_name": "zavychromaxl_v100.safetensors"
    }
  },
  "2": {
    "class_type": "LoadImage",
    "inputs": {
      "image": "{{input_image}}"
    }
  },
  "3": {
    "class_type": "VAEEncode",
    "inputs": {
      "pixels": ["2", 0],
      "vae": ["1", 2]
    }
  },
  "4": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "text": "{{prompt}}",
      "clip": ["1", 1]
    }
  },
  "5": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "text": "{{negative_prompt}}",
      "clip": ["1", 1]
    }
  },
  "6": {
    "class_type": "ControlNetLoader",
    "inputs": {
      "control_net_name": "controlnet-canny-sdxl-1.0.safetensors"
    }
  },
  "7": {
    "class_type": "Canny",
    "_comment": "Extract edges from source. strength=0.55 preserves edges without over-constraining.",
    "inputs": {
      "image": ["2", 0],
      "low_threshold": 0.4,
      "high_threshold": 0.8
    }
  },
  "8": {
    "class_type": "ControlNetApplyAdvanced",
    "inputs": {
      "positive": ["4", 0],
      "negative": ["5", 0],
      "control_net": ["6", 0],
      "image": ["7", 0],
      "strength": 0.55,
      "start_percent": 0.0,
      "end_percent": 0.8,
      "vae": ["1", 2]
    }
  },
  "9": {
    "class_type": "KSampler",
    "inputs": {
      "model": ["1", 0],
      "positive": ["8", 0],
      "negative": ["8", 1],
      "latent_image": ["3", 0],
      "seed": "{{seed}}",
      "steps": 15,
      "cfg": 6.0,
      "sampler_name": "dpmpp_2m_sde_gpu",
      "scheduler": "karras",
      "denoise": "{{denoise}}"
    }
  },
  "10": {
    "class_type": "VAEDecode",
    "inputs": {
      "samples": ["9", 0],
      "vae": ["1", 2]
    }
  },
  "11": {
    "class_type": "SaveImage",
    "inputs": {
      "images": ["10", 0],
      "filename_prefix": "creative_suite/style_edge_chrome"
    }
  }
}
