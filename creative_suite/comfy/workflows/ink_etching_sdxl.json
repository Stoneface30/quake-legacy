{
  "_template_version": "1",
  "_description": "Woodblock print / ink etching via dense Canny (0.1/0.4) + Union ProMax at maximum strength (1.0). Low Canny thresholds capture every surface crease as an ink line. cfg=12.0 is intentionally extreme \u2014 forces maximum commitment to the etching/linocut prompt. JuggernautXL at 30 steps with ddim/ddim_uniform for sharp, committed edges. Best at denoise=0.65\u20130.75.",
  "_notes": [
    "Low Canny thresholds (0.1/0.4) detect subtle gradients as lines \u2014 creates the dense crosshatch texture of etchings.",
    "ControlNet strength=1.0 + end_percent=0.95 \u2014 the ink lines govern the full diffusion pass.",
    "cfg=12.0 is very high by SDXL standards. Correct here: we want the model fully committed to ink style, not hedging.",
    "ddim + ddim_uniform: deterministic sampler produces clean, crisp output \u2014 no SDE blur = sharp etching edges."
  ],
  "_placeholders": [
    "{{input_image}}",
    "{{prompt}}",
    "{{seed}}",
    "{{denoise}}",
    "{{negative_prompt}}"
  ],
  "1": {
    "class_type": "CheckpointLoaderSimple",
    "inputs": {
      "ckpt_name": "juggernautXL_ragnarokBy.safetensors"
    }
  },
  "2": {
    "class_type": "LoadImage",
    "inputs": {
      "image": "{{input_image}}"
    }
  },
  "3": {
    "class_type": "UpscaleModelLoader",
    "inputs": {
      "model_name": "4x-UltraSharp.pth"
    }
  },
  "4": {
    "class_type": "ImageUpscaleWithModel",
    "inputs": {
      "upscale_model": [
        "3",
        0
      ],
      "image": [
        "2",
        0
      ]
    }
  },
  "5": {
    "class_type": "ImageScaleBy",
    "inputs": {
      "image": [
        "4",
        0
      ],
      "upscale_method": "lanczos",
      "scale_by": 0.5
    }
  },
  "6": {
    "class_type": "VAEEncode",
    "inputs": {
      "pixels": [
        "5",
        0
      ],
      "vae": [
        "1",
        2
      ]
    }
  },
  "7": {
    "_comment": "Dense detection (0.1/0.4) = every crease becomes an ink line, mimicking etching crosshatch",
    "class_type": "Canny",
    "inputs": {
      "image": [
        "5",
        0
      ],
      "low_threshold": 0.1,
      "high_threshold": 0.4
    }
  },
  "8": {
    "class_type": "ControlNetLoader",
    "inputs": {
      "control_net_name": "controlnet-canny-sdxl-1.0.safetensors"
    }
  },
  "9": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "text": "{{prompt}}",
      "clip": [
        "1",
        1
      ]
    }
  },
  "10": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "text": "{{negative_prompt}}",
      "clip": [
        "1",
        1
      ]
    }
  },
  "11": {
    "_comment": "Max strength=1.0 + end_percent=0.95 \u2014 ink lines own the entire diffusion pass",
    "class_type": "ControlNetApplyAdvanced",
    "inputs": {
      "positive": [
        "9",
        0
      ],
      "negative": [
        "10",
        0
      ],
      "control_net": [
        "8",
        0
      ],
      "image": [
        "7",
        0
      ],
      "vae": [
        "1",
        2
      ],
      "strength": 1.0,
      "start_percent": 0.0,
      "end_percent": 0.95
    }
  },
  "12": {
    "_comment": "cfg=12.0 intentional \u2014 maximum style commitment. ddim_uniform = deterministic, sharp lines.",
    "class_type": "KSampler",
    "inputs": {
      "model": [
        "1",
        0
      ],
      "positive": [
        "11",
        0
      ],
      "negative": [
        "11",
        1
      ],
      "latent_image": [
        "6",
        0
      ],
      "seed": "{{seed}}",
      "steps": 15,
      "cfg": 12.0,
      "sampler_name": "ddim",
      "scheduler": "ddim_uniform",
      "denoise": "{{denoise}}"
    }
  },
  "13": {
    "class_type": "VAEDecode",
    "inputs": {
      "samples": [
        "12",
        0
      ],
      "vae": [
        "1",
        2
      ]
    }
  },
  "14": {
    "class_type": "SaveImage",
    "inputs": {
      "images": [
        "13",
        0
      ],
      "filename_prefix": "creative_suite/ink_etching"
    }
  }
}