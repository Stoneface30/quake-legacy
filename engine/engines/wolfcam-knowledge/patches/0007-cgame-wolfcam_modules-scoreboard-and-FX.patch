+	if (cg.time - cg.pingCalculateTime > 5000) {
+		//int samples;
+
+		for (totalSum = 0, i = 0 /*, samples = 0*/;  i < LAG_SAMPLES  &&  i < lagometer.snapshotCount;  i++) {
+			int val;
