+	}
+
+	sft = cg.serverFrameTime;
+
+	//Com_Printf("ping: %d\n", ping);
+
+	if (sft <= 0  ||  sft > 200) {
+		sft = serverFrameTime;
+	}
+
+	if (isBot) {
+		ping -= (sft / 2);
+	}
+
+	while ((float)ping > ((float)sft / 2.0)) {
