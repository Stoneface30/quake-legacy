+void CG_GetModelAndSkinName (const char *s, char *model, char *skin)
+{
+	char *p;
+
+	model[0] = '\0';
+	skin[0] = '\0';
+
+	Q_strncpyz(model, s, MAX_QPATH);
+	if ((p = strchr(model, '/')) == NULL) {
+		model[0] = '\0';
+		Q_strncpyz(skin, s, MAX_QPATH);
+		return;
+	} else {
+		*p++ = '\0';
+	}
+
+	Q_strncpyz(skin, p, MAX_QPATH);
