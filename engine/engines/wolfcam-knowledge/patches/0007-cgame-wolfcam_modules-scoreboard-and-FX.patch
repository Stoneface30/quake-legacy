+static localEntity_t *CG_AllocFxEntity (float id)
+{
+	localEntity_t *le;
+
+	le = CG_AllocLocalEntity();
+	if (id < 0.0) {
+		CG_MakeLowPriorityEntity(le);
+	}
+
+	return le;
+}
