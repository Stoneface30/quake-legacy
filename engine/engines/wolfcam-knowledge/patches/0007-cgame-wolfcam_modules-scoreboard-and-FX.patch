+static const char *PrintShort (const char *s, int len)
+{
+	static char buffer[1024];
+	int n;
+
+	if (len >= sizeof(buffer)) {
+		n = sizeof(buffer);
+	} else {
+		n = len;
+	}
+
+	Q_strncpyz(buffer, s, n);
+
+	return buffer;
+}
