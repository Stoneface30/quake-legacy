+void CG_GetModelName (const char *s, char *model)
+{
+	char *p;
+
+	model[0] = '\0';
+
+	Q_strncpyz(model, s, MAX_QPATH);
+	if ((p = strchr(model, '/')) == NULL) {
+		// just a model listed
+		return;
+	} else {
+		*p++ = '\0';
+	}
+}
