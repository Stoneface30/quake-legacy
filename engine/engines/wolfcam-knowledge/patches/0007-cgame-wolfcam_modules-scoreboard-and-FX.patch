+    if (tokenId) {
+		switch (tokenId) {
+		case TOKEN_ORIGIN:
+			goto origintoken;
+			break;
+
+		case TOKEN_V0:
+			goto v0token;
+			break;
+		case TOKEN_V1:
+			goto v1token;
+			break;
+		case TOKEN_V2:
+			goto v2token;
+			break;
